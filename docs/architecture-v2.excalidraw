    {
      "type": "text",
      "id": "el145",
      "x": 40,
      "y": 1230,
      "width": 783.2,
      "height": 20.0,
      "text": "Deployment: One gateway per environment (dev / stg / prd) \u2014 no cross-environment routing.",
      "fontSize": 16,
      "fontFamily": 5,
      "strokeColor": "#757575",
      "textAlign": "left",
      "verticalAlign": "top",
      "originalText": "Deployment: One gateway per environment (dev / stg / prd) \u2014 no cross-environment routing.",
      "autoResize": true
    },
    {
      "type": "text",
      "id": "el146",
      "x": 40,
      "y": 1255,
      "width": 1012.0000000000001,
      "height": 20.0,
      "text": "AKS via company CI/CD templates. Graceful shutdown: SIGTERM -> drain 30s -> flush audit -> exit (35s grace period).",
      "fontSize": 16,
      "fontFamily": 5,
      "strokeColor": "#757575",
      "textAlign": "left",
      "verticalAlign": "top",
      "originalText": "AKS via company CI/CD templates. Graceful shutdown: SIGTERM -> drain 30s -> flush audit -> exit (35s grace period).",
      "autoResize": true
    },
    {
      "type": "text",
      "id": "el147",
      "x": 40,
      "y": 1280,
      "width": 1139.6000000000001,
      "height": 17.5,
      "text": "Degradation: PG down -> 503 + disk fallback audit | Queue down -> disk buffer + retry | API down -> Polly circuit breaker | Dynatrace down -> silent",
      "fontSize": 14,
      "fontFamily": 5,
      "strokeColor": "#757575",
      "textAlign": "left",
      "verticalAlign": "top",
      "originalText": "Degradation: PG down -> 503 + disk fallback audit | Queue down -> disk buffer + retry | API down -> Polly circuit breaker | Dynatrace down -> silent",
      "autoResize": true
    }
